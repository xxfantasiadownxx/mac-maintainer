#!/bin/bash

echo ""
echo "========================================"
echo "          Mac Recovery Toolkit"
echo "========================================"
echo ""

# --- Prompt for user input ---
read -p "Enter FileVault Recovery Key: " RECOVERY_KEY
read -p "Enter new admin username: " NEW_USER
read -p "Enter real name for admin: " REAL_NAME
read -p "Enter new password for $NEW_USER: " NEW_PASS
read -p "Enter new UID for $NEW_USER (e.g., 502): " UNIQUE_ID
echo "Group ID will be set to 80 (admin group)."
sleep 2

# --- Assign Group ID ---
GROUP_ID=80

# --- Show disk layout ---
diskutil list
read -p "Where is Macintosh HD - Data mapped to (include /dev/ in path): " DATA_VOL

# --- Unlock FileVault Data volume ---
echo "[*] Unlocking FileVault Data volume..."
sleep 1
diskutil apfs unlockVolume "$DATA_VOL" -passphrase "$RECOVERY_KEY"

# --- Mount Data volume ---
echo "[*] Mounting Data volume..."
sleep 1
diskutil mount "$DATA_VOL"

# --- Define mount path ---
DATA_MOUNT="/Volumes/Macintosh HD - Data"

# --- Create user record directly on mounted volume (FIX for dscl auth issue) ---
echo "[*] Creating new admin user on target volume..."
sleep 1

dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -create "/Local/Default/Users/$NEW_USER"
sleep 0.5
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -create "/Local/Default/Users/$NEW_USER" UserShell /bin/zsh
sleep 0.5
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -create "/Local/Default/Users/$NEW_USER" RealName "$REAL_NAME"
sleep 0.5
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -create "/Local/Default/Users/$NEW_USER" UniqueID "$UNIQUE_ID"
sleep 0.5
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -create "/Local/Default/Users/$NEW_USER" PrimaryGroupID "$GROUP_ID"
sleep 0.5
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -create "/Local/Default/Users/$NEW_USER" NFSHomeDirectory "/Users/$NEW_USER"
sleep 0.5

# --- Set password properly (FIXED) ---
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -passwd "/Local/Default/Users/$NEW_USER" "$NEW_PASS"
sleep 0.5

# --- Add to admin group ---
dscl -f "$DATA_MOUNT/private/var/db/dslocal/nodes/Default" localhost -append "/Local/Default/Groups/admin" GroupMembership "$NEW_USER"

# --- Create home directory on Data volume ---
echo "[*] Creating home directory..."
sleep 1
mkdir -p "$DATA_MOUNT/Users/$NEW_USER"
chown -R "$UNIQUE_ID:$GROUP_ID" "$DATA_MOUNT/Users/$NEW_USER"
chmod 755 "$DATA_MOUNT/Users/$NEW_USER"
sleep 1

echo "[*] Admin account '$NEW_USER' created successfully!"
sleep 2

read -p "Reboot now? (y/n): " DO_REBOOT
if [[ "$DO_REBOOT" =~ ^[Yy]$ ]]; then
  reboot
fi
